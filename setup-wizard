<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>网站配置向导 - 健康计算器</title>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); min-height: 100vh; color: #1F2937; line-height: 1.6; }
  .container { max-width: 720px; margin: 0 auto; padding: 40px 20px; }
  .header { text-align: center; color: #fff; padding: 40px 0 20px; }
  .header h1 { font-size: 32px; font-weight: 700; margin-bottom: 8px; }
  .header p { font-size: 16px; opacity: 0.9; }
  .card { background: #fff; border-radius: 16px; padding: 32px; margin-bottom: 20px; box-shadow: 0 8px 32px rgba(0,0,0,0.12); }
  .card h2 { font-size: 20px; font-weight: 700; margin-bottom: 8px; color: #374151; display: flex; align-items: center; gap: 10px; }
  .card h2 .step-num { background: linear-gradient(135deg, #667eea, #764ba2); color: #fff; width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 16px; flex-shrink: 0; }
  .card .subtitle { font-size: 14px; color: #6B7280; margin-bottom: 20px; padding-left: 42px; }
  .form-group { margin-bottom: 20px; }
  .form-group label { display: block; font-size: 14px; font-weight: 600; color: #374151; margin-bottom: 6px; }
  .form-group .hint { font-size: 12px; color: #9CA3AF; font-weight: 400; margin-left: 4px; }
  .form-group input { width: 100%; padding: 12px 16px; border: 2px solid #E5E7EB; border-radius: 10px; font-size: 16px; font-family: "SF Mono", "Consolas", monospace; transition: border-color 0.2s; color: #1F2937; }
  .form-group input:focus { outline: none; border-color: #667eea; box-shadow: 0 0 0 3px rgba(102,126,234,0.15); }
  .form-group input.valid { border-color: #10B981; }
  .form-group .status { display: none; font-size: 12px; margin-top: 4px; }
  .status.ok { color: #10B981; display: block; }
  .status.warn { color: #F59E0B; display: block; }
  .btn-row { display: flex; gap: 12px; flex-wrap: wrap; }
  .btn { padding: 12px 24px; border-radius: 10px; font-size: 15px; font-weight: 600; cursor: pointer; border: none; font-family: inherit; transition: all 0.2s; display: inline-flex; align-items: center; gap: 8px; }
  .btn-primary { background: linear-gradient(135deg, #667eea, #764ba2); color: #fff; box-shadow: 0 4px 14px rgba(102,126,234,0.35); }
  .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(102,126,234,0.45); }
  .btn-secondary { background: #F3F4F6; color: #374151; }
  .btn-secondary:hover { background: #E5E7EB; }
  .btn-outline { background: #fff; color: #667eea; border: 2px solid #667eea; }
  .btn-outline:hover { background: #F5F3FF; }
  .link-card { display: flex; align-items: center; gap: 12px; padding: 14px 16px; background: #F9FAFB; border-radius: 10px; margin-bottom: 10px; text-decoration: none; color: #1F2937; transition: all 0.2s; border: 2px solid transparent; }
  .link-card:hover { border-color: #667eea; background: #F5F3FF; }
  .link-card .lc-icon { font-size: 24px; width: 44px; height: 44px; background: #fff; border-radius: 10px; display: flex; align-items: center; justify-content: center; box-shadow: 0 2px 8px rgba(0,0,0,0.06); flex-shrink: 0; }
  .link-card .lc-info { flex: 1; }
  .link-card .lc-title { font-size: 15px; font-weight: 600; }
  .link-card .lc-desc { font-size: 12px; color: #6B7280; }
  .preview-box { background: #1F2937; color: #10B981; padding: 16px; border-radius: 10px; font-family: "SF Mono", "Consolas", monospace; font-size: 13px; overflow-x: auto; white-space: pre-wrap; word-break: break-all; max-height: 300px; overflow-y: auto; }
  .preview-box .highlight { color: #FBBF24; }
  .toast { position: fixed; top: 20px; left: 50%; transform: translateX(-50%); background: #1F2937; color: #fff; padding: 14px 28px; border-radius: 12px; font-size: 14px; font-weight: 500; z-index: 9999; opacity: 0; pointer-events: none; transition: opacity 0.3s; box-shadow: 0 8px 24px rgba(0,0,0,0.3); }
  .toast.show { opacity: 1; }
  .toast.success { background: #059669; }
  .progress-bar { height: 4px; background: #E5E7EB; border-radius: 2px; margin: 20px 0; overflow: hidden; }
  .progress-bar .fill { height: 100%; background: linear-gradient(90deg, #667eea, #764ba2); border-radius: 2px; transition: width 0.5s ease; }
  .checklist { list-style: none; padding: 0; }
  .checklist li { padding: 8px 0; font-size: 14px; display: flex; align-items: center; gap: 8px; }
  @media (max-width: 640px) { .card { padding: 20px; } .header h1 { font-size: 24px; } .btn-row { flex-direction: column; } .btn { justify-content: center; } }
</style>
</head>
<body>
<div class="container">
  <div class="header">
    <h1>网站配置向导</h1>
    <p>完成 Google 服务配置，让网站开始收集数据并盈利</p>
  </div>

  <div class="card">
    <div class="progress-bar"><div class="fill" id="progressFill" style="width: 0%"></div></div>
    <p style="text-align:center;font-size:14px;color:#6B7280;">完成进度: <strong id="progressText">0/4</strong> 步</p>
  </div>

  <div class="card">
    <h2><span class="step-num">1</span> 创建 Google 服务账号</h2>
    <p class="subtitle">点击下方链接，用 1906255309@qq.com 登录创建（每个约2分钟）</p>
    <a class="link-card" href="https://analytics.google.com" target="_blank" rel="noopener">
      <div class="lc-icon">&#128202;</div>
      <div class="lc-info"><div class="lc-title">Google Analytics 4 (GA4)</div><div class="lc-desc">创建账号 - 属性 - 数据流，获取 Measurement ID (G-XXXXXX)</div></div>
    </a>
    <a class="link-card" href="https://tagmanager.google.com" target="_blank" rel="noopener">
      <div class="lc-icon">&#127991;</div>
      <div class="lc-info"><div class="lc-title">Google Tag Manager (GTM)</div><div class="lc-desc">创建账号 - 容器，获取 Container ID (GTM-XXXXXX)</div></div>
    </a>
    <a class="link-card" href="https://adsense.google.com" target="_blank" rel="noopener">
      <div class="lc-icon">&#128176;</div>
      <div class="lc-info"><div class="lc-title">Google AdSense</div><div class="lc-desc">申请广告账号，获取发布商 ID (ca-pub-XXXXXX)</div></div>
    </a>
    <a class="link-card" href="https://search.google.com/search-console" target="_blank" rel="noopener">
      <div class="lc-icon">&#128269;</div>
      <div class="lc-info"><div class="lc-title">Google Search Console</div><div class="lc-desc">完成网站所有权验证，提交 sitemap</div></div>
    </a>
  </div>

  <div class="card">
    <h2><span class="step-num">2</span> 填入你的 ID</h2>
    <p class="subtitle">从上面创建的服务中复制 ID，粘贴到下面</p>
    <div class="form-group">
      <label>GA4 测量 ID <span class="hint">格式: G-XXXXXXXXXX</span></label>
      <input type="text" id="ga4Input" placeholder="G-" oninput="validateInputs()">
      <span class="status" id="ga4Status"></span>
    </div>
    <div class="form-group">
      <label>GTM 容器 ID <span class="hint">格式: GTM-XXXXXXX</span></label>
      <input type="text" id="gtmInput" placeholder="GTM-" oninput="validateInputs()">
      <span class="status" id="gtmStatus"></span>
    </div>
    <div class="form-group">
      <label>AdSense 发布商 ID <span class="hint">格式: ca-pub-XXXXXXXXXXXX</span></label>
      <input type="text" id="adsenseInput" placeholder="ca-pub-" oninput="validateInputs()">
      <span class="status" id="adsenseStatus"></span>
    </div>
    <div class="btn-row">
      <button class="btn btn-primary" onclick="previewConfig()" id="previewBtn" disabled>预览配置</button>
      <button class="btn btn-secondary" onclick="downloadConfig()" id="downloadBtn" disabled>下载配置文件</button>
      <button class="btn btn-secondary" onclick="copyConfig()" id="copyBtn" disabled>复制配置</button>
    </div>
  </div>

  <div class="card" id="previewCard" style="display:none;">
    <h2><span class="step-num">3</span> 配置预览</h2>
    <div class="preview-box" id="previewContent"></div>
    <div style="margin-top:16px;" class="btn-row">
      <button class="btn btn-primary" onclick="goToActions()">去 GitHub Actions 一键部署</button>
    </div>
  </div>

  <div class="card">
    <h2><span class="step-num">4</span> 验证清单</h2>
    <ul class="checklist">
      <li><span id="check1">&#10060;</span> 网站首页加载正常</li>
      <li><span id="check2">&#10060;</span> GA4 实时数据可见</li>
      <li><span id="check3">&#10060;</span> GTM 容器已发布</li>
      <li><span id="check4">&#10060;</span> Search Console 验证通过</li>
      <li><span id="check5">&#10060;</span> Sitemap 已提交</li>
      <li><span id="check6">&#10060;</span> AdSense 审核中</li>
    </ul>
    <div style="margin-top:16px;">
      <a href="/dashboard" class="btn btn-outline">打开运营控制面板</a>
    </div>
  </div>

  <div class="card" style="text-align:center;">
    <p style="font-size:14px;color:#6B7280;">需要帮助？查看 <a href="/deploy-guide" style="color:#667eea;">完整部署指南</a></p>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
(function() {
  function validateInputs() {
    var ga4 = document.getElementById('ga4Input').value.trim();
    var gtm = document.getElementById('gtmInput').value.trim();
    var adsense = document.getElementById('adsenseInput').value.trim();
    var validCount = 0;

    var ga4Valid = /^G-[A-Z0-9]{8,}$/i.test(ga4);
    document.getElementById('ga4Status').className = 'status' + (ga4 ? (ga4Valid ? ' ok' : ' warn') : '');
    document.getElementById('ga4Status').textContent = ga4 ? (ga4Valid ? '格式正确' : '格式不正确') : '';
    document.getElementById('ga4Input').className = ga4 ? (ga4Valid ? 'valid' : '') : '';
    if (ga4Valid) validCount++;

    var gtmValid = /^GTM-[A-Z0-9]{6,}$/i.test(gtm);
    document.getElementById('gtmStatus').className = 'status' + (gtm ? (gtmValid ? ' ok' : ' warn') : '');
    document.getElementById('gtmStatus').textContent = gtm ? (gtmValid ? '格式正确' : '格式不正确') : '';
    document.getElementById('gtmInput').className = gtm ? (gtmValid ? 'valid' : '') : '';
    if (gtmValid) validCount++;

    var adsenseValid = /^ca-pub-\d{10,}$/i.test(adsense);
    document.getElementById('adsenseStatus').className = 'status' + (adsense ? (adsenseValid ? ' ok' : ' warn') : '');
    document.getElementById('adsenseStatus').textContent = adsense ? (adsenseValid ? '格式正确' : '格式不正确') : '';
    document.getElementById('adsenseInput').className = adsense ? (adsenseValid ? 'valid' : '') : '';
    if (adsenseValid) validCount++;

    var hasAny = ga4Valid || gtmValid || adsenseValid;
    document.getElementById('previewBtn').disabled = !hasAny;
    document.getElementById('downloadBtn').disabled = !hasAny;
    document.getElementById('copyBtn').disabled = !hasAny;

    updateProgress(validCount);
  }

  function updateProgress(count) {
    var pct = Math.round((count / 4) * 100);
    document.getElementById('progressFill').style.width = pct + '%';
    document.getElementById('progressText').textContent = count + '/4';
  }

  function getConfig() {
    return {
      ga4_measurement_id: document.getElementById('ga4Input').value.trim() || 'G-XXXXXXXXXX',
      gtm_container_id: document.getElementById('gtmInput').value.trim() || 'GTM-XXXXXXX',
      adsense_publisher_id: document.getElementById('adsenseInput').value.trim() || 'ca-pub-',
      website: 'https://1-seven-lovat-14.vercel.app'
    };
  }

  function showToast(msg, type) {
    var toast = document.getElementById('toast');
    toast.textContent = msg;
    toast.className = 'toast show ' + (type || '');
    setTimeout(function() { toast.className = 'toast'; }, 4000);
  }

  window.previewConfig = function() {
    var config = getConfig();
    document.getElementById('previewCard').style.display = 'block';
    var json = JSON.stringify(config, null, 2);
    json = json.replace(/"([^"]+)":/g, '<span class="highlight">"$1"</span>:');
    json = json.replace(/: "([^"]+)"/g, ': "<span class="highlight">$1</span>"');
    document.getElementById('previewContent').innerHTML = json;
    document.getElementById('previewCard').scrollIntoView({behavior: 'smooth'});
  };

  window.downloadConfig = function() {
    var config = getConfig();
    var blob = new Blob([JSON.stringify(config, null, 2)], {type: 'application/json'});
    var url = URL.createObjectURL(blob);
    var a = document.createElement('a');
    a.href = url;
    a.download = 'google_ids.json';
    a.click();
    URL.revokeObjectURL(url);
    showToast('配置文件已下载', 'success');
  };

  window.copyConfig = function() {
    var config = getConfig();
    navigator.clipboard.writeText(JSON.stringify(config, null, 2)).then(function() {
      showToast('配置已复制到剪贴板', 'success');
    });
  };

  window.goToActions = function() {
    window.open('https://github.com/Cuibingyan-sys/1/actions/workflows/setup-google-services.yml', '_blank');
    showToast('在新页面中点击 Run workflow, 选择仅更新代码, 填入ID后运行', 'success');
  };

  window.validateInputs = validateInputs;

  var saved = localStorage.getItem('google_ids_config');
  if (saved) {
    try {
      var config = JSON.parse(saved);
      if (config.ga4_measurement_id && config.ga4_measurement_id !== 'G-XXXXXXXXXX')
        document.getElementById('ga4Input').value = config.ga4_measurement_id;
      if (config.gtm_container_id && config.gtm_container_id !== 'GTM-XXXXXXX')
        document.getElementById('gtmInput').value = config.gtm_container_id;
      if (config.adsense_publisher_id && config.adsense_publisher_id !== 'ca-pub-')
        document.getElementById('adsenseInput').value = config.adsense_publisher_id;
      validateInputs();
    } catch(e) {}
  }

  ['ga4Input','gtmInput','adsenseInput'].forEach(function(id) {
    document.getElementById(id).addEventListener('change', function() {
      localStorage.setItem('google_ids_config', JSON.stringify(getConfig()));
    });
  });
})();
</script>
</body>
</html>
